<?xml version="1.0" encoding="UTF-8"?>
<window>
    <defaultcontrol>300</defaultcontrol>
    <controls>
        <!-- Background with fanart -->
        <control type="group">
            <animation effect="zoom" start="0" end="100" time="200" center="auto" tween="quadratic" easing="out">WindowOpen</animation>
            <!-- Fanart background -->
            <control type="image">
                <left>0</left>
                <top>0</top>
                <width>1920</width>
                <height>1080</height>
                <texture fallback="special://home/addons/plugin.video.asguard/fanart.jpg">$INFO[Window.Property(asguard.source_progress.fanart)]</texture>
                <aspectratio>scale</aspectratio>
                <colordiffuse>FFFFFFFF</colordiffuse>
                <fadetime>200</fadetime>
            </control>
            <!-- Dark overlay -->
            <control type="image">
                <left>0</left>
                <top>0</top>
                <width>1920</width>
                <height>1080</height>
                <texture colordiffuse="CC000000">black.png</texture>
            </control>
        </control>

        <!-- Main content group - centered like POV -->
        <control type="group">
            <centerleft>50%</centerleft>
            <centertop>50%</centertop>
            <width>1152</width>
            <height>868</height>

            <!-- Background panel -->
            <control type="image">
                <texture colordiffuse="80343434">white.png</texture>
            </control>

            <!-- Header -->
            <control type="label">
                <left>0</left>
                <top>60</top>
                <width>1152</width>
                <height>60</height>
                <font>font45</font>
                <textcolor>FFFFFFFF</textcolor>
                <shadowcolor>FF000000</shadowcolor>
                <align>center</align>
                <aligny>center</aligny>
                <label>$INFO[Window.Property(asguard.source_progress.header)]</label>
            </control>

            <!-- Status lines -->
            <control type="label">
                <left>0</left>
                <top>100</top>
                <width>1152</width>
                <height>50</height>
                <font>font30</font>
                <textcolor>FFFFFFFF</textcolor>
                <shadowcolor>FF000000</shadowcolor>
                <align>center</align>
                <aligny>center</aligny>
                <label>$INFO[Window.Property(asguard.source_progress.line1)]</label>
            </control>
            <control type="label">
                <left>0</left>
                <top>155</top>
                <width>1152</width>
                <height>50</height>
                <font>font30</font>
                <textcolor>FFFFFFFF</textcolor>
                <shadowcolor>FF000000</shadowcolor>
                <align>center</align>
                <aligny>center</aligny>
                <label>$INFO[Window.Property(asguard.source_progress.line2)]</label>
            </control>
            <control type="label">
                <left>0</left>
                <top>210</top>
                <width>1152</width>
                <height>50</height>
                <font>font30</font>
                <textcolor>FFFFFFFF</textcolor>
                <shadowcolor>FF000000</shadowcolor>
                <align>center</align>
                <aligny>center</aligny>
                <label>$INFO[Window.Property(asguard.source_progress.line3)]</label>
            </control>
            <control type="label">
                <left>0</left>
                <top>265</top>
                <width>1152</width>
                <height>50</height>
                <font>font30</font>
                <textcolor>FFFFFFFF</textcolor>
                <shadowcolor>FF000000</shadowcolor>
                <align>center</align>
                <aligny>center</aligny>
                <label>$INFO[Window.Property(asguard.source_progress.line4)]</label>
            </control>

            <!-- Progress section -->
            <control type="group">
                <left>0</left>
                <top>330</top>
                <width>1152</width>
                <height>200</height>

                <!-- Elapsed time label -->
                <control type="label">
                    <left>0</left>
                    <top>0</top>
                    <width>1152</width>
                    <height>40</height>
                    <font>font30</font>
                    <textcolor>FF00A8E8</textcolor>
                    <shadowcolor>FF000000</shadowcolor>
                    <align>center</align>
                    <aligny>center</aligny>
                    <label>$INFO[Window.Property(asguard.source_progress.elapsed)]</label>
                </control>

                <!-- Progress bar -->
                <control type="progress" id="200">
                    <left>226</left>
                    <top>50</top>
                    <width>700</width>
                    <height>20</height>
                    
                    <lefttexture>-</lefttexture>
                    <righttexture>-</righttexture>
                    <overlaytexture>-</overlaytexture>
                </control>

                <!-- Current scraper label -->
                <control type="label">
                    <left>0</left>
                    <top>85</top>
                    <width>1152</width>
                    <height>40</height>
                    <font>font30</font>
                    <textcolor>FF00A8E8</textcolor>
                    <shadowcolor>FF000000</shadowcolor>
                    <align>center</align>
                    <aligny>center</aligny>
                    <label>$INFO[Window.Property(asguard.source_progress.scraper)]</label>
                </control>

                <!-- Quality label -->
                <control type="label">
                    <left>0</left>
                    <top>130</top>
                    <width>1152</width>
                    <height>40</height>
                    <font>font30</font>
                    <textcolor>FF00A8E8</textcolor>
                    <shadowcolor>FF000000</shadowcolor>
                    <align>center</align>
                    <aligny>center</aligny>
                    <label>$INFO[Window.Property(asguard.source_progress.quality)]</label>
                </control>
            </control>

            <!-- Counts label -->
            <control type="label">
                <left>0</left>
                <top>540</top>
                <width>1152</width>
                <height>40</height>
                <font>font30</font>
                <textcolor>FF00A8E8</textcolor>
                <shadowcolor>FF000000</shadowcolor>
                <align>center</align>
                <aligny>center</aligny>
                <label>$INFO[Window.Property(asguard.source_progress.counts)]</label>
            </control>

            <!-- Cancel Button -->
            <control type="button" id="300">
                <centerleft>50%</centerleft>
                <top>600</top>
                <width>200</width>
                <height>60</height>
                <label>Cancel</label>
                <font>font30</font>
                <textcolor>FFB7B4BB</textcolor>
                <focusedcolor>FF00A8E8</focusedcolor>
                <texturefocus colordiffuse="FFCCCCCC">white.png</texturefocus>
                <texturenofocus colordiffuse="FF302F2F">white.png</texturenofocus>
                <align>center</align>
                <aligny>center</aligny>
            </control>
        </control>
    </controls>
</window>
